<!DOCTYPE html>
<html>
<head>
  <title>Login</title>

  <link rel="stylesheet" href="/style.css">

  <link
    rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
  >
</head>

<body>

  <% if (erro) { %>

   <div class="alert">
     <%= erro %>
   </div>

  <% } %>

  <button
    class="theme-btn"
    id="themeButton"
    onclick="toggleTheme()"
  >
    ☀️
  </button>

  <div class="container">

    <div class="logo">
      <i class="fa-solid fa-user"></i>
    </div>

    <h1 class="title">
      Acesse sua conta
    </h1>

    <form action="/login" method="POST">

      <div class="input-group">
         <input
           type="text"
           name="email"
           placeholder="E-mail"
           required
         >
      </div>

      <div class="input-group password-group">

        <input
          type="password"
          name="senha"
          placeholder="Senha"
          id="senha"
          required
        >

        <i
          class="fa-regular fa-eye eye-icon"
          onclick="togglePassword()"
        ></i>

</div>

      <button type="submit">
        Entrar
      </button>

    </form>

    <div class="link">
      <a href="/register">
        Criar conta
      </a>
    </div>

  </div>

  <script src="/theme.js"></script>

</body>
</html>
